# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Build artifacts
*.egg-info/
dist/
build/

# Logs
logs/
*.log
**/*.log

