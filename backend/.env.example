# ============================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# For Docker/Dokploy: Use service names (postgres, redis)

# Database Configuration
# Docker: DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/law_agent_db
# Local:  DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/law_agent_db
DATABASE_URL=postgresql://postgres:Rahul%40123@postgres:5432/law_agent_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=law_agent_db
DB_USER=postgres
DB_PASSWORD=Rahul@123

# LLM Provider: "gemini" or "openrouter"
LLM_PROVIDER=openrouter

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter API (Used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenAI API (For RAG embeddings)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Firecrawl API (For web scraping in RAG - optional)
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# Google Cloud (OPTIONAL)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://legalops-api.apexneural.cloud/auth/google/callback

# Translation
TRANSLATION_SERVICE=gemini

# File Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Redis
# Docker: redis://redis:6379/0
# Local:  redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# Security (Generate new keys for production!)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Feature Flags
ENABLE_LIVE_TRANSCRIPTION=false
ENABLE_FULL_TEXT_LOGGING=false
ENABLE_PII_REDACTION=true

# PayPal Configuration (OPTIONAL)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# SendGrid Configuration (OPTIONAL)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com

# Frontend Configuration (REQUIRED)
# Production URLs
FRONTEND_URL=https://legalops.apexneural.cloud
FRONTEND_RESET_URL=https://legalops.apexneural.cloud/reset-password

# OCR Configuration
OCR_ENGINE=auto
TESSERACT_CMD=
OCR_LANGUAGES=eng+msa
GOOGLE_VISION_API_KEY=

# Legal Database
CASELAW_DB_TYPE=commonlii
USE_COMMONLII=true
CASELAW_API_URL=
CASELAW_API_KEY=

# CORS - Production + Local for testing
CORS_ORIGINS=["https://legalops.apexneural.cloud","https://www.legalops.apexneural.cloud","http://localhost:3000","http://127.0.0.1:3000","http://localhost:8006","http://127.0.0.1:8006","http://localhost:8007","http://127.0.0.1:8007"]
CORS_ALLOW_ALL=false

# Backend Port
BACKEND_PORT=8091

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
