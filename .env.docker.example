# ============================================
# Docker Environment Example
# ============================================
# Copy this file to .env in the root directory
# and fill in your production values

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=law_agent_db
DB_PORT=5432

# Backend Configuration
BACKEND_PORT=8091
LOG_LEVEL=INFO

# Frontend Configuration
FRONTEND_PORT=8006
NEXT_PUBLIC_API_URL=https://your-backend-domain.com
NEXT_PUBLIC_APP_URL=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# LLM Provider Configuration
# Options: "gemini" or "openrouter"
LLM_PROVIDER=gemini

# Gemini API (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter API (required if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Security (IMPORTANT: Generate new keys for production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_change_this

# CORS Configuration
# For production, set specific origins. Use comma-separated list.
CORS_ORIGINS=https://your-frontend-domain.com
CORS_ALLOW_ALL=false

# PayPal Integration (Optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

# SendGrid Email (Optional)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
